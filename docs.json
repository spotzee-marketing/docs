{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Spotzee",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "index",
              "guides/quickstart",
              "guides/concepts"
            ]
          },
          {
            "group": "Build",
            "icon": "wrench",
            "pages": [
              "guides/journeys",
              "guides/segments",
              "guides/channels",
              "guides/authentication"
            ]
          }
        ]
      },
      {
        "tab": "Main API",
        "groups": [
          {
            "group": "Overview",
            "icon": "terminal",
            "pages": [
              "main-api/introduction",
              "main-api/errors"
            ]
          }
        ]
      },
      {
        "tab": "Extended API",
        "groups": [
          {
            "group": "Overview",
            "icon": "bolt",
            "pages": [
              "extended-api/introduction",
              "extended-api/errors"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "href": "https://status.spotzee.com",
          "icon": "signal"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@spotzee.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Sign in",
        "href": "https://app.spotzee.com/sign-in"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://app.spotzee.com/sign-up"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/spotzee",
      "linkedin": "https://linkedin.com/company/spotzee"
    }
  }
}
