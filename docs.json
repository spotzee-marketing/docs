{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Spotzee",
  "description": "Marketing automation for every business — purpose-built for financial services",
  "colors": {
    "primary": "#6a75f1",
    "light": "#5a84e9",
    "dark": "#004aad"
  },
  "favicon": "/favicon.svg",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "go"
      ],
      "defaults": "required",
      "autogenerate": true
    },
    "spec": {
      "download": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "guides/quickstart",
              "guides/concepts"
            ]
          },
          {
            "group": "Build",
            "pages": [
              "guides/journeys",
              "guides/segments",
              "guides/channels",
              "guides/providers",
              "guides/authentication"
            ]
          },
          {
            "group": "API conventions",
            "pages": [
              "guides/api-versioning",
              "guides/api-rate-limits",
              "guides/api-idempotency",
              "guides/api-pagination",
              "guides/api-webhooks",
              "guides/api-client-type"
            ]
          },
          {
            "group": "Recipes",
            "pages": [
              "guides/sync-contacts",
              "guides/event-ingestion",
              "guides/build-segment-via-api",
              "guides/trigger-campaign",
              "guides/journey-trigger"
            ]
          },
          {
            "group": "Releases",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "Main API",
        "openapi": "https://apix.spotzee.com/api/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "main-api/introduction",
              "main-api/errors"
            ]
          },
          {
            "group": "Projects",
            "tag": "Projects"
          },
          {
            "group": "Contacts",
            "tag": "Contacts"
          },
          {
            "group": "Events",
            "tag": "Events"
          },
          {
            "group": "Lists",
            "tag": "Lists"
          },
          {
            "group": "Subscriptions",
            "tag": "Subscriptions"
          },
          {
            "group": "Templates",
            "tag": "Templates"
          },
          {
            "group": "Campaigns",
            "tag": "Campaigns"
          },
          {
            "group": "Journeys",
            "tag": "Journeys"
          },
          {
            "group": "Tags",
            "tag": "Tags"
          },
          {
            "group": "API keys",
            "tag": "API keys"
          },
          {
            "group": "Organisation",
            "tag": "Organisation"
          },
          {
            "group": "Webhooks",
            "tag": "Webhooks"
          }
        ]
      },
      {
        "tab": "Extended API",
        "openapi": "https://apix.spotzee.com/api/ext/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "extended-api/introduction",
              "extended-api/errors"
            ]
          },
          {
            "group": "AI",
            "tag": "AI"
          },
          {
            "group": "DNS",
            "tag": "DNS"
          },
          {
            "group": "Email",
            "tag": "Email"
          },
          {
            "group": "SMS",
            "tag": "SMS"
          },
          {
            "group": "Text",
            "tag": "Text"
          },
          {
            "group": "Data",
            "tag": "Data"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.spotzee.com",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg",
    "href": "https://docs.spotzee.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://spotzee.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://app.spotzee.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://www.twitter.com/spotzeemarketin",
      "linkedin": "https://www.linkedin.com/company/spotzee-marketing",
      "facebook": "https://www.facebook.com/spotzeemarketing",
      "github": "https://github.com/spotzee-marketing",
      "youtube": "https://www.youtube.com/@spotzeemarketing"
    }
  },
  "fonts": {
    "family": "Lato",
    "weight": 400,
    "heading": {
      "family": "Lato",
      "weight": 900
    },
    "body": {
      "family": "Lato",
      "weight": 400
    }
  },
  "appearance": {
    "default": "system"
  }
}
