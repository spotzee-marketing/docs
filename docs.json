{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Spotzee",
  "description": "Marketing automation for every business — purpose-built for financial services",
  "colors": {
    "primary": "#6a75f1",
    "light": "#5a84e9",
    "dark": "#004aad"
  },
  "favicon": "/favicon.svg",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "autogenerate": true
    },
    "spec": {
      "download": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "index",
              "guides/quickstart",
              "guides/concepts"
            ]
          },
          {
            "group": "Build",
            "icon": "wrench",
            "pages": [
              "guides/journeys",
              "guides/segments",
              "guides/channels",
              "guides/authentication"
            ]
          }
        ]
      },
      {
        "tab": "Main API",
        "openapi": "https://apix.spotzee.com/api/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "icon": "terminal",
            "pages": [
              "main-api/introduction"
            ]
          },
          {
            "group": "Authentication",
            "icon": "key",
            "pages": [
              "main-api/authentication"
            ]
          },
          {
            "group": "Versioning",
            "icon": "tag",
            "pages": [
              "main-api/versioning"
            ]
          },
          {
            "group": "Rate limits",
            "icon": "gauge",
            "pages": [
              "main-api/rate-limits"
            ]
          },
          {
            "group": "Idempotency",
            "icon": "shield",
            "pages": [
              "main-api/idempotency"
            ]
          },
          {
            "group": "Pagination",
            "icon": "list",
            "pages": [
              "main-api/pagination"
            ]
          },
          {
            "group": "Webhooks",
            "icon": "webhook",
            "pages": [
              "main-api/webhooks"
            ]
          },
          {
            "group": "Errors",
            "icon": "circle-exclamation",
            "pages": [
              "main-api/errors"
            ]
          }
        ]
      },
      {
        "tab": "Extended API",
        "openapi": "https://app.spotzee.com/api/ext/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "icon": "bolt",
            "pages": [
              "extended-api/introduction",
              "extended-api/errors"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.spotzee.com",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg",
    "href": "https://docs.spotzee.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://spotzee.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://app.spotzee.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://www.twitter.com/spotzeemarketin",
      "linkedin": "https://www.linkedin.com/company/spotzee-marketing",
      "facebook": "https://www.facebook.com/spotzeemarketing",
      "github": "https://github.com/spotzee-marketing",
      "youtube": "https://www.youtube.com/@spotzeemarketing"
    }
  },
  "fonts": {
    "family": "Lato",
    "weight": 400,
    "heading": {
      "family": "Lato",
      "weight": 900
    },
    "body": {
      "family": "Lato",
      "weight": 400
    }
  },
  "appearance": {
    "default": "system"
  }
}
